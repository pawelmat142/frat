{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      { "tsconfig": "test/tsconfig.json" }
    ]
  },
  "moduleNameMapper": {
    "^@shared/(.*)$": "<rootDir>/../shared/$1"
  },
  "modulePaths": ["<rootDir>/src"]
}
